<Window x:Class="VehicleRentalSystem.Component2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VehicleRentalSystem.Component2"
        mc:Ignorable="d"
        Title="Vehicle Rental - Component 2" Height="600" Width="900">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Load Vehicles -->
        <Button Grid.Row="0"
                Content="Load Vehicles"
                Command="{Binding VehicleSelection.LoadVehiclesCommand}"
                Width="120"
                HorizontalAlignment="Left"
                Margin="0,0,0,8" />

        <!-- Vehicle picker -->
        <ComboBox Grid.Row="1"
                  ItemsSource="{Binding VehicleSelection.Vehicles}"
                  SelectedItem="{Binding VehicleSelection.SelectedVehicle}"
                  Width="360"
                  HorizontalAlignment="Left"
                  Margin="0,0,0,8">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock>
                        <Run Text="{Binding Brand, Mode=OneWay}" />
                        <Run Text=" " />
                        <Run Text="{Binding Model, Mode=OneWay}" />
                        <Run Text=" — " />
                        <Run Text="{Binding LicensePlate, Mode=OneWay}" />
                    </TextBlock>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <!-- Vehicle load status -->
        <TextBlock Grid.Row="2"
                   Text="{Binding VehicleSelection.StatusMessage}"
                   HorizontalAlignment="Left"
                   Margin="0,0,0,8" />

        <!-- Month / Year inputs + Load Rental Records -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Year:" VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBox Text="{Binding RentalRecords.Year, UpdateSourceTrigger=PropertyChanged}"
                     Width="60" Margin="0,0,12,0" />
            <TextBlock Text="Month:" VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBox Text="{Binding RentalRecords.Month, UpdateSourceTrigger=PropertyChanged}"
                     Width="40" Margin="0,0,12,0" />
            <Button Content="Load Rental Records"
                    Command="{Binding RentalRecords.LoadRentalRecordsCommand}"
                    Width="150" />
        </StackPanel>

        <!-- Adapted groups DataGrid -->
        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding RentalRecords.AdaptedGroups}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="0,0,0,8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Key"         Binding="{Binding Key}"            Width="*" />
                <DataGridTextColumn Header="Rental Date" Binding="{Binding RentalDateText}" Width="130" />
                <DataGridTextColumn Header="Count"       Binding="{Binding Count}"          Width="55" />
                <DataGridTextColumn Header="Records"     Binding="{Binding RecordsText}"    Width="2*" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Rental records load status -->
        <TextBlock Grid.Row="5"
                   Text="{Binding RentalRecords.StatusMessage}"
                   HorizontalAlignment="Left" />
    </Grid>
</Window>
