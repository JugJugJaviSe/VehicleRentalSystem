<Window x:Class="VehicleRentalSystem.Component2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VehicleRentalSystem.Component2"
        mc:Ignorable="d"
        Title="Vehicle Rental - Component 2" Height="600" Width="900">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Load Vehicles -->
        <Button Grid.Row="0"
                Content="Load Vehicles"
                Command="{Binding VehicleSelection.LoadVehiclesCommand}"
                Width="120"
                HorizontalAlignment="Left"
                Margin="0,0,0,8" />

        <!-- Vehicle picker -->
        <ComboBox Grid.Row="1"
                  ItemsSource="{Binding VehicleSelection.Vehicles}"
                  SelectedItem="{Binding VehicleSelection.SelectedVehicle}"
                  Width="360"
                  HorizontalAlignment="Left"
                  Margin="0,0,0,8">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock>
                        <Run Text="{Binding Brand, Mode=OneWay}" />
                        <Run Text=" " />
                        <Run Text="{Binding Model, Mode=OneWay}" />
                        <Run Text=" — " />
                        <Run Text="{Binding LicensePlate, Mode=OneWay}" />
                    </TextBlock>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <!-- Vehicle load status -->
        <TextBlock Grid.Row="2"
                   Text="{Binding VehicleSelection.StatusMessage}"
                   HorizontalAlignment="Left"
                   Margin="0,0,0,8" />

        <!-- Month / Year inputs + Load Rental Records -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Year:" VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBox Text="{Binding RentalRecords.YearInputText, UpdateSourceTrigger=PropertyChanged}"
                     Width="60" Margin="0,0,12,0" />
            <TextBlock Text="Month:" VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBox Text="{Binding RentalRecords.MonthInputText, UpdateSourceTrigger=PropertyChanged}"
                     Width="40" Margin="0,0,12,0" />
            <Button Content="Load Rental Records"
                    Command="{Binding RentalRecords.LoadRentalRecordsCommand}"
                    Width="150" />
            <Button Content="Clear Displayed Data"
                    Command="{Binding RentalRecords.ClearRentalRecordsCommand}"
                    Width="140"
                    Margin="8,0,0,0" />
        </StackPanel>

        <!-- Cached rental record groups -->
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
            <ItemsControl ItemsSource="{Binding RentalRecords.DisplayedGroups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Margin="0,0,0,4" FontWeight="SemiBold">
                                <Run Text="Vehicle ID: " />
                                <Run Text="{Binding VehicleId, Mode=OneWay}" />
                                <Run Text="   Rental period: " />
                                <Run Text="{Binding RentalPeriod, Mode=OneWay}" />
                                <Run Text="   Record count: " />
                                <Run Text="{Binding RecordCount, Mode=OneWay}" />
                            </TextBlock>
                            <DataGrid ItemsSource="{Binding Records}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Rental Date"        Binding="{Binding RentalDate, StringFormat=yyyy-MM-dd HH:mm}" Width="140" />
                                    <DataGridTextColumn Header="Duration Days"      Binding="{Binding DurationDays}"                              Width="100" />
                                    <DataGridTextColumn Header="Total Cost (RSD)"   Binding="{Binding TotalCost, StringFormat=F2}"                Width="120" />
                                    <DataGridTextColumn Header="Mileage Driven (km)" Binding="{Binding MileageDriven, StringFormat=F2}"           Width="140" />
                                    <DataGridTextColumn Header="State"              Binding="{Binding State}"                                     Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Rental records load status -->
        <TextBlock Grid.Row="5"
                   Text="{Binding RentalRecords.StatusMessage}"
                   HorizontalAlignment="Left"
                   Margin="0,0,0,8" />

        <!-- Strategy statistics -->
        <StackPanel Grid.Row="6" Margin="0,4,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Statistic:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <ComboBox ItemsSource="{Binding RentalStatistics.AvailableStrategies}"
                          SelectedItem="{Binding RentalStatistics.SelectedStrategy}"
                          DisplayMemberPath="Name"
                          Width="180"
                          Margin="0,0,8,0" />
                <TextBlock Text="{Binding RentalStatistics.SelectedStatisticResult}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
                <Button Content="Export CSV"
                        Command="{Binding RentalStatistics.ExportStatisticCommand}"
                        Width="100"
                        Margin="12,0,0,0" />
            </StackPanel>
            <TextBlock Text="Statistics are calculated from all displayed rental records."
                       FontSize="11"
                       Foreground="Gray"
                       Margin="0,4,0,0" />
            <TextBlock Text="{Binding RentalStatistics.ExportStatusMessage}"
                       FontSize="11"
                       Foreground="DarkSlateGray"
                       Margin="0,2,0,0" />
        </StackPanel>
    </Grid>
</Window>
