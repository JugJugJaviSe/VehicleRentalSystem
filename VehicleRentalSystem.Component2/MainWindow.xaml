<Window x:Class="VehicleRentalSystem.Component2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VehicleRentalSystem.Component2"
        mc:Ignorable="d"
        Title="Vehicle Rental - Component 2" Height="450" Width="800">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Button Grid.Row="0"
                Content="Load Vehicles"
                Command="{Binding VehicleSelection.LoadVehiclesCommand}"
                Width="120"
                HorizontalAlignment="Left"
                Margin="0,0,0,8" />

        <ComboBox Grid.Row="1"
                  ItemsSource="{Binding VehicleSelection.Vehicles}"
                  SelectedItem="{Binding VehicleSelection.SelectedVehicle}"
                  Width="360"
                  HorizontalAlignment="Left"
                  Margin="0,0,0,8">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock>
                        <Run Text="{Binding Brand, Mode=OneWay}" />
                        <Run Text=" " />
                        <Run Text="{Binding Model, Mode=OneWay}" />
                        <Run Text=" — " />
                        <Run Text="{Binding LicensePlate, Mode=OneWay}" />
                    </TextBlock>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Grid.Row="2"
                   Text="{Binding VehicleSelection.StatusMessage}"
                   HorizontalAlignment="Left" />
    </Grid>
</Window>
