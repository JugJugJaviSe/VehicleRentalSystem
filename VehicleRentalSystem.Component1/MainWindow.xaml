<Window x:Class="VehicleRentalSystem.Component1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="Vehicle Rental System"
        Height="700"
        Width="1200">

    <Grid Margin="10">
        <TabControl>
            <TabItem Header="Vehicles"
                     DataContext="{Binding VehicleManagement}">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="0,0,0,8">
                        <Button Content="Add Vehicle"
                                Command="{Binding AddVehicleCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Edit Vehicle"
                                Command="{Binding EditVehicleCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Delete Vehicle"
                                Command="{Binding DeleteVehicleCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Undo"
                                Command="{Binding UndoVehicleCommand}"
                                Margin="16,0,8,0" />
                        <Button Content="Redo"
                                Command="{Binding RedoVehicleCommand}"
                                Margin="0,0,8,0" />
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             Text="{Binding VehicleSearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8"
                             ToolTip="Search vehicles"
                             MinHeight="24" />

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding VehiclesView}"
                              SelectedItem="{Binding SelectedVehicle}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id"
                                                Binding="{Binding Id}" />
                            <DataGridTextColumn Header="License Plate"
                                                Binding="{Binding LicensePlate}" />
                            <DataGridTextColumn Header="Brand"
                                                Binding="{Binding Brand}" />
                            <DataGridTextColumn Header="Model"
                                                Binding="{Binding Model}" />
                            <DataGridTextColumn Header="Year"
                                                Binding="{Binding ProductionYear}" />
                            <DataGridTextColumn Header="Fuel"
                                                Binding="{Binding FuelType}" />
                            <DataGridCheckBoxColumn Header="Available"
                                                    Binding="{Binding IsAvailable}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Rental Records"
                     DataContext="{Binding RentalManagement}">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="0,0,0,8">
                        <Button Content="Add Rental"
                                Command="{Binding AddRentalRecordCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Edit Rental"
                                Command="{Binding EditRentalRecordCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Delete Rental"
                                Command="{Binding DeleteRentalRecordCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Undo"
                                Command="{Binding UndoRentalCommand}"
                                Margin="16,0,8,0" />
                        <Button Content="Redo"
                                Command="{Binding RedoRentalCommand}"
                                Margin="0,0,8,0" />
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             Text="{Binding RentalSearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8"
                             ToolTip="Search rental records"
                             MinHeight="24" />

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding RentalRecordsView}"
                              SelectedItem="{Binding SelectedRentalRecord}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id"
                                                Binding="{Binding Id}" />
                            <DataGridTextColumn Header="Vehicle Id"
                                                Binding="{Binding VehicleId}" />
                            <DataGridTextColumn Header="Rental Date"
                                                Binding="{Binding RentalDate}" />
                            <DataGridTextColumn Header="Duration"
                                                Binding="{Binding DurationDays}" />
                            <DataGridTextColumn Header="Total Cost"
                                                Binding="{Binding TotalCost}" />
                            <DataGridTextColumn Header="Mileage"
                                                Binding="{Binding MileageDriven}" />
                            <DataGridTextColumn Header="State"
                                                Binding="{Binding State}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Statistics">
                <Grid Margin="16"
                      DataContext="{Binding Statistics}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <lvc:PieChart Grid.Column="0"
                                  Series="{Binding Series}"
                                  LegendPosition="Right" />

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="24">
                        <TextBlock Text="Rental State Counts"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,16" />
                        <TextBlock Text="{Binding ActiveCount, StringFormat=Active: {0}}"
                                   FontSize="16"
                                   Margin="0,4" />
                        <TextBlock Text="{Binding CompletedCount, StringFormat=Completed: {0}}"
                                   FontSize="16"
                                   Margin="0,4" />
                        <TextBlock Text="{Binding CancelledCount, StringFormat=Cancelled: {0}}"
                                   FontSize="16"
                                   Margin="0,4" />
                        <TextBlock Text="{Binding OverdueCount, StringFormat=Overdue: {0}}"
                                   FontSize="16"
                                   Margin="0,4" />
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
