<Window x:Class="VehicleRentalSystem.Component1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vehicle Rental System"
        Height="700"
        Width="1200">

    <Grid Margin="10">
        <TabControl>
            <TabItem Header="Vehicles">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="0,0,0,8">
                        <Button Content="Add Vehicle"
                                Command="{Binding AddVehicleCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Edit Vehicle"
                                Command="{Binding EditVehicleCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Delete Vehicle"
                                Command="{Binding DeleteVehicleCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Undo"
                                Command="{Binding VehicleUndoCommand}"
                                Margin="16,0,8,0" />
                        <Button Content="Redo"
                                Command="{Binding VehicleRedoCommand}"
                                Margin="0,0,8,0" />
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             Text="{Binding VehicleSearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8"
                             ToolTip="Search vehicles"
                             MinHeight="24" />

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding Vehicles}"
                              SelectedItem="{Binding SelectedVehicle}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="License Plate"
                                                Binding="{Binding LicensePlate}" />
                            <DataGridTextColumn Header="Brand"
                                                Binding="{Binding Brand}" />
                            <DataGridTextColumn Header="Model"
                                                Binding="{Binding Model}" />
                            <DataGridTextColumn Header="Year"
                                                Binding="{Binding ProductionYear}" />
                            <DataGridTextColumn Header="Fuel"
                                                Binding="{Binding FuelType}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Rental Records">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="0,0,0,8">
                        <Button Content="Add Rental"
                                Command="{Binding AddRentalRecordCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Edit Rental"
                                Command="{Binding EditRentalRecordCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Delete Rental"
                                Command="{Binding DeleteRentalRecordCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Complete Rental"
                                Command="{Binding CompleteRentalCommand}"
                                Margin="16,0,8,0" />
                        <Button Content="Cancel Rental"
                                Command="{Binding CancelRentalCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Mark Overdue"
                                Command="{Binding MarkOverdueCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Undo"
                                Command="{Binding RentalUndoCommand}"
                                Margin="16,0,8,0" />
                        <Button Content="Redo"
                                Command="{Binding RentalRedoCommand}"
                                Margin="0,0,8,0" />
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             Text="{Binding RentalSearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8"
                             ToolTip="Search rental records"
                             MinHeight="24" />

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding RentalRecords}"
                              SelectedItem="{Binding SelectedRentalRecord}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Vehicle Id"
                                                Binding="{Binding VehicleId}" />
                            <DataGridTextColumn Header="Rental Date"
                                                Binding="{Binding RentalDate}" />
                            <DataGridTextColumn Header="Duration"
                                                Binding="{Binding DurationDays}" />
                            <DataGridTextColumn Header="Total Cost"
                                                Binding="{Binding TotalCost}" />
                            <DataGridTextColumn Header="Mileage"
                                                Binding="{Binding MileageDriven}" />
                            <DataGridTextColumn Header="State"
                                                Binding="{Binding State}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Statistics">
                <Grid>
                    <TextBlock Text="Statistics will be implemented here."
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="18" />
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
